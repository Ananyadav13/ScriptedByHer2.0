# One key is enough to run:
GEMINI_API_KEY=your-gemini-api-key-here

# OPTIONAL: a pool of keys (each a separate Google project) for daily-cap failover.
# The free tier is 20 requests/day PER project; the app rotates to the next key on
# exhaustion. Comma-separated; takes precedence over GEMINI_API_KEY when set.
# The clean alternative is enabling billing (removes the daily cap entirely).
# GEMINI_API_KEYS=key1,key2,key3

DATABASE_URL=sqlite:///./build_trust.db

# Comma-separated list of browser origins allowed to call this API.
FRONTEND_ORIGIN=http://localhost:3000

# true  -> drop + reseed on every boot (clean demo, the dev default)
# false -> create tables if missing and seed only when empty (data survives restarts)
SEED_RESET=true

# Gemini model for both agents. gemini-2.5-* is retired for new keys and the pro tiers
# 429 on the free quota; gemini-3-flash-preview is the verified working model here.
LLM_MODEL=gemini-3-flash-preview

# Logging. LOG_DIR receives a rotating app.log (5MB x 3 backups) alongside console output.
# Set LOG_DIR= (empty) for console-only, e.g. on a PaaS with no writable disk.
LOG_LEVEL=INFO
LOG_DIR=logs
