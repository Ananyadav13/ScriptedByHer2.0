# One key is enough to run:
GEMINI_API_KEY=your-gemini-api-key-here

# OPTIONAL: a pool of keys (each a separate Google project) for daily-cap failover.
# The free tier is 20 requests/day PER project; the app rotates to the next key on
# exhaustion. Comma-separated; takes precedence over GEMINI_API_KEY when set.
# The clean alternative is enabling billing (removes the daily cap entirely).
# GEMINI_API_KEYS=key1,key2,key3

DATABASE_URL=sqlite:///./build_trust.db
FRONTEND_ORIGIN=http://localhost:3000
